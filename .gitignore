# ═══════════════════════════════════════════════════════════════════════
#  .gitignore — tesis-hardware-peru
#  Estrategia:
#    data/raw/        → Git LFS (datos únicos de scraping)
#    data/features/   → ignorado (335 MB, derivado de MASTER)
#    data/processed/  → ignorado (derivados regenerables)
#    models/          → git normal para artefactos < 10 MB
#                       git LFS para modelos > 50 MB
# ═══════════════════════════════════════════════════════════════════════

# ── Entornos virtuales ────────────────────────────────────────────────
venv/
venv_pe4/
.venv/
env/

# ── Python ────────────────────────────────────────────────────────────
*.pyc
__pycache__/
*.egg-info/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs y temporales ─────────────────────────────────────────────────
*.log
*.bak
*.html
pcp_debug.html

# ── Modelos grandes (> 50 MB) → usar Git LFS manualmente ─────────────
*.bin
*.pt
*.pth
*.h5
*.hdf5
*.ckpt

# ── PKL: ignorar por defecto, excepto artefactos pequeños versionados ─
*.pkl
!models/zscore_normalizer.pkl
!models/mice_imputer.pkl

# ── data/raw: solo ignorar snapshots pesados y backups ───────────────
data/raw/master_raw.parquet
data/raw/newegg_full_snapshot.json
data/raw/MASTER_hardware_peru_OLD_BUGGY.csv
data/raw/MASTER_hardware_peru_REBUILT.csv
data/raw/MASTER_hardware_peru_BACKUP_*.csv
data/raw/batch_test_*.csv
data/raw/batch_newegg_*.csv
data/raw/newegg_raw_*.csv
data/raw/newegg_*.html

# ── data/features: 335 MB, derivado de MASTER (regenerable) ──────────
data/features/

# ── data/processed: derivados regenerables ───────────────────────────
data/processed/*.csv
data/processed/*.parquet
data/processed/quality_report_*.json
data/processed/split_report_*.json
data/processed/mice_report_*.json

# ── data/ raíz: CSVs/JSONs sueltos de scraping ───────────────────────
data/precios_*.csv
data/precios_*.json

# ── models/: predicciones de test (derivadas) ────────────────────────
models/test_predictions_*.csv

# ── Archivos temporales del agente ───────────────────────────────────
apply_patch.py
patch_newegg.py
setup_dashboard.sh
10k,*
