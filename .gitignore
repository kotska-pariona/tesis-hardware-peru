# ── Entornos virtuales ────────────────────────────────────────
venv_pe4/
venv/
.venv/
env/

# ── Modelos grandes (DVC) ─────────────────────────────────────
*.pkl
*.bin
*.pt
*.pth
*.h5
*.hdf5
*.ckpt

# ── data/raw: permitir CSVs y JSONs de scraping ───────────────
# NO ignorar data/raw/ completo — GitHub Actions necesita commitear aquí
# Solo ignorar archivos muy pesados o temporales dentro de raw/
data/raw/master_raw.parquet
data/raw/newegg_full_snapshot.json
data/raw/MASTER_hardware_peru_OLD_BUGGY.csv
data/raw/MASTER_hardware_peru_REBUILT.csv
data/raw/MASTER_hardware_peru_BACKUP_*.csv
data/raw/batch_test_*.csv
data/raw/batch_newegg_*.csv

# ── data/processed y features (gestionadas por DVC) ──────────
data/processed/MASTER_hardware_peru*.csv
data/processed/*.parquet
data/processed/mice_imputer.pkl
data/features/zscore_normalizer.pkl
data/features/*.pkl

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Archivos temporales ───────────────────────────────────────
*.pyc
__pycache__/
*.log
pcp_debug.html
*.html
*.bak
*.v[0-9]*.bak
.DS_Store
Thumbs.db

# ── Archivos temporales del agente ───────────────────────────
tash
price_pen
apply_patch.py
patch_newegg.py
setup_dashboard.sh
newegg_raw_*.csv
newegg_*.html
10k,*

# ── Excepciones: permitir punteros DVC ───────────────────────
!models/*.dvc

# Archivos procesados derivados — se regeneran con pe5_agent.py
data/processed/*.csv
data/processed/oportunidades_roi.csv

# CSVs/JSONs sueltos en data/ (fuera de raw/)
data/precios_*.csv
data/precios_*.json

# Reportes temporales del pipeline — se regeneran en cada run
data/processed/quality_report_*.json
data/processed/split_report_*.json
data/processed/mice_report_*.json

# Predicciones de test de modelos ML — derivadas, no versionar
models/test_predictions_*.csv

# Features dataset — 335 MB, derivado de MASTER_CSV
# Regenerar con: python agent/pipeline.py --features
data/features/
